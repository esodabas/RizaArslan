# Root .gitignore

# Environment files - NEVER commit these
backend/.env
.env
*.env

# Node modules
node_modules/
backend/node_modules/
frontend/node_modules/

# Frontend build output
frontend/dist/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Uploads (user content - should use Cloudinary in production)
backend/uploads/*
!backend/uploads/.gitkeep

# Test files
backend/test-api.js
backend/test-sqljs.js
backend/data/
